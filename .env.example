# Database (MySQL Workbench)
DATABASE_URL="mysql://user:password@127.0.0.1:3306/reglens?charset=utf8mb4"

# AI (Mistral)
MISTRAL_API_KEY=""
MISTRAL_MODEL="mistral-small-latest"
MISTRAL_EMBED_MODEL="mistral-embed"

# Auth (NextAuth)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET=""

# OAuth – Google (isteğe bağlı; tanımlıysa giriş sayfasında “Google ile giriş” görünür)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth – GitHub (isteğe bağlı; tanımlıysa giriş sayfasında “GitHub ile giriş” görünür)
# Callback URL: http://localhost:3000/api/auth/callback/github (veya NEXTAUTH_URL + /api/auth/callback/github)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Cron (cron endpoint'leri için secret)
CRON_SECRET=""

# Encryption (production'da güçlü bir key kullanın)
ENCRYPTION_KEY=""

# Rate limiting (Upstash Redis – isteğe bağlı)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Email (isteğe bağlı)
SENDGRID_API_KEY=""
